{
  "Keycloak": {
    "realm": "tips-steps",
    "auth-server-url": "http://keycloak:8080/",
    "ssl-required": "none",
    "resource": "tns-usermgmt",
    "verify-token-audience": false,
    "Admin": {
      "BaseUrl": "http://keycloak:8080",
      "Realm": "tips-steps",
      "ClientId": "tns-admin-cli",
      "ClientSecret": "change-me-in-production"
    }
  },
  "MongoDB": {
    "ConnectionString": "mongodb://host.docker.internal:27017",
    "DatabaseName": "tips-steps-usermgmt",
    "ReadReplicaConnectionString": "mongodb://host.docker.internal:27017"
  },
  "Kafka": {
    "BootstrapServers": "host.docker.internal:9092",
    "SchemaRegistryUrl": "http://schema-registry:8081",
    "GroupId": "tns-usermgmt-group"
  },
  "Redis": {
    "ConnectionString": "redis:6379",
    "DefaultTtlMinutes": 60
  },
  "Seq": { "Url": "http://seq:80" },
  "Urls": "http://+:8080"
}
